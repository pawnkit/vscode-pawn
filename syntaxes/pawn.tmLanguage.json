{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Pawn",
  "scopeName": "source.pawn",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "match": "^\\s*#\\s*(include|tryinclude|define|if|elseif|else|endif|pragma|error|warning|assert|undef|emit|line|file|endinput)\\b", "name": "keyword.control.directive.pawn" },
    { "match": "\\b(assert|break|case|continue|default|do|else|exit|for|goto|if|return|sleep|state|switch|while)\\b", "name": "keyword.control.pawn" },
    { "match": "\\b(char|defined|sizeof|tagof)\\b", "name": "keyword.operator.pawn" },
    { "match": "\\b(const|enum|forward|native|new|operator|public|static|stock)\\b", "name": "storage.type.pawn" },
    { "match": "\\b(true|false)\\b", "name": "constant.language.pawn" },
    { "match": "\\b(0[xX][0-9a-fA-F]+|0[bB][01]+|[0-9]+(?:\\.[0-9]*)?(?:[eE][+-]?[0-9]+)?)\\b", "name": "constant.numeric.pawn" }
  ],
  "repository": {
    "comments": { "patterns": [{ "begin": "/\\*", "end": "\\*/", "name": "comment.block.pawn" }, { "match": "//.*$", "name": "comment.line.double-slash.pawn" }] },
    "strings": { "patterns": [{ "begin": "\"", "end": "\"", "name": "string.quoted.double.pawn", "patterns": [{ "match": "(?:\\\\|\\^).", "name": "constant.character.escape.pawn" }] }, { "begin": "'", "end": "'", "name": "string.quoted.single.pawn", "patterns": [{ "match": "(?:\\\\|\\^).", "name": "constant.character.escape.pawn" }] }] }
  }
}
