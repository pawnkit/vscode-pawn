{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Pawn",
  "scopeName": "source.pawn",
  "patterns": [
    { "include": "#comments" },
    {
      "begin": "^(\\s*)(#)\\s*(include|tryinclude)\\b",
      "beginCaptures": {
        "2": { "name": "punctuation.definition.directive.pawn" },
        "3": { "name": "keyword.control.directive.include.pawn" }
      },
      "end": "$",
      "name": "meta.preprocessor.include.pawn",
      "patterns": [
        {
          "match": "(<)([^>]+)(>)",
          "name": "string.quoted.other.include.pawn",
          "captures": {
            "1": { "name": "punctuation.definition.string.begin.pawn" },
            "3": { "name": "punctuation.definition.string.end.pawn" }
          }
        },
        { "include": "#strings" },
        { "include": "#comments" }
      ]
    },
    { "include": "#strings" },
    {
      "match": "^(\\s*)(#)\\s*(define)\\s+([A-Za-z_@][A-Za-z0-9_@]*)",
      "captures": {
        "2": { "name": "punctuation.definition.directive.pawn" },
        "3": { "name": "keyword.control.directive.pawn" },
        "4": { "name": "entity.name.constant.preprocessor.pawn" }
      }
    },
    {
      "match": "^(\\s*)(#)\\s*(if|elseif|else|endif|pragma|error|warning|assert|undef|emit|line|file|endinput)\\b",
      "captures": {
        "2": { "name": "punctuation.definition.directive.pawn" },
        "3": { "name": "keyword.control.directive.pawn" }
      }
    },
    { "match": "\\b(assert|break|case|continue|default|do|else|exit|for|goto|if|return|sleep|state|switch|while)\\b", "name": "keyword.control.pawn" },
    {
      "match": "\\b(defined)\\s+([A-Za-z_@][A-Za-z0-9_@]*)",
      "captures": {
        "1": { "name": "keyword.control.directive.conditional.pawn" },
        "2": { "name": "entity.name.constant.preprocessor.pawn" }
      }
    },
    { "match": "\\bdefined\\b", "name": "keyword.control.directive.conditional.pawn" },
    { "match": "\\b(char|sizeof|tagof)\\b", "name": "keyword.operator.pawn" },
    { "match": "\\b(const|enum|forward|native|new|operator|public|static|stock)\\b", "name": "storage.type.pawn" },
    {
      "match": "^(\\s*)(?:(public|stock|static|native|forward)\\s+)?(?:([A-Za-z_@][A-Za-z0-9_@]*):)?([A-Za-z_@][A-Za-z0-9_@]*)(?=\\s*\\()",
      "captures": {
        "2": { "name": "storage.type.pawn" },
        "3": { "name": "entity.name.type.tag.pawn" },
        "4": { "name": "entity.name.function.definition.pawn" }
      }
    },
    { "match": "\\b[A-Za-z_@][A-Za-z0-9_@]*(?=:(?!:))", "name": "entity.name.type.tag.pawn" },
    { "match": "\\b[A-Za-z_@][A-Za-z0-9_@]*(?=\\s*\\()", "name": "entity.name.function.pawn" },
    { "match": "\\b[A-Z][A-Z0-9_]{2,}\\b", "name": "constant.other.pawn" },
    { "match": "\\b(true|false)\\b", "name": "constant.language.pawn" },
    { "match": "\\b(0[xX][0-9a-fA-F]+|0[bB][01]+|[0-9]+(?:\\.[0-9]*)?(?:[eE][+-]?[0-9]+)?)\\b", "name": "constant.numeric.pawn" },
    { "match": "(?:==|!=|<=|>=|&&|\\|\\||<<|>>|\\+\\+|--|[+\\-*/%<>=!&|^~])", "name": "keyword.operator.pawn" }
  ],
  "repository": {
    "comments": { "patterns": [{ "begin": "/\\*", "end": "\\*/", "name": "comment.block.pawn" }, { "match": "//.*$", "name": "comment.line.double-slash.pawn" }] },
    "strings": { "patterns": [{ "begin": "\"", "end": "\"", "name": "string.quoted.double.pawn", "patterns": [{ "match": "(?:\\\\|\\^).", "name": "constant.character.escape.pawn" }] }, { "begin": "'", "end": "'", "name": "string.quoted.single.pawn", "patterns": [{ "match": "(?:\\\\|\\^).", "name": "constant.character.escape.pawn" }] }] }
  }
}
